{
  "name": "clinical-care",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:web": "npm run dev --workspace @clinical/web",
    "build:web": "npm run build --workspace @clinical/web",
    "build:shared": "npm run build --workspace @clinical/shared",
    "build": "npm run build:shared && npm run build:web",
    "lint": "npm run lint --workspaces --if-present",
    "test": "npm run test --workspaces --if-present"
  }
}
