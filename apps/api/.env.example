# Copy to .env and fill in. NEVER commit the real .env (it's gitignored).

# Postgres connection (matches docker-compose.yml for local dev)
DATABASE_URL="postgresql://clinical:localdevpassword@localhost:5432/clinical_care?schema=public"

# JWT signing secrets — generate strong random values, e.g.:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_ACCESS_SECRET="replace-with-a-long-random-string"
JWT_REFRESH_SECRET="replace-with-a-different-long-random-string"

# Which frontend origin may call this API (CORS allowlist)
CORS_ORIGIN="http://localhost:5173"

# Server
PORT=4000
NODE_ENV=development
